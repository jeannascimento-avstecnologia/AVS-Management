# Sem colchetes [] — apenas o valor do token
TIFLUX_API_TOKEN=SEU_TOKEN_JWT_TIFLUX
VHSYS_ACCESS_TOKEN=SEU_ACCESS_TOKEN
VHSYS_SECRET_ACCESS_TOKEN=SEU_SECRET_ACCESS_TOKEN
BRASILAPI_BASE_URL=https://brasilapi.com.br/api/cnpj/v1
TIFLUX_BASE_URL=https://api.tiflux.com/api/v2
# ID de cliente visível no TiFlux para copiar desk_ids e technical_group_ids
TIFLUX_REFERENCE_CLIENT_ID=31116
# Opcional: sobrescrever mesas/grupos (IDs separados por vírgula)
# TIFLUX_DESK_IDS=36089,64230
# TIFLUX_TECHNICAL_GROUP_IDS=8324,25705
VHSYS_BASE_URL=https://api.vhsys.com/v2
REQUIRE_ACTIVE_CNPJ=true
USER_AGENT=AVS-Management/1.4
TIFLUX_DEFAULT_DESK_NAMES=Comercial,Serviços Avulsos,Vendas

# Autenticação local (e-mail + senha)
AUTH_ENABLED=true
AUTH_PROVIDER=local
SESSION_SECRET=change-me-in-production-use-long-random-string
APP_BASE_URL=http://127.0.0.1:8000
AUTH_DB_PATH=data/auth.db
SESSION_IDLE_HOURS=8
REMEMBER_ME_DAYS=30
PASSWORD_RESET_TOKEN_HOURS=1
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# SMTP Microsoft 365 (recuperação de senha)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@avs.com.br
SMTP_PASSWORD=
SMTP_FROM=AVS Management <noreply@avs.com.br>
SMTP_USE_TLS=true

# Lista usada pelo seed de usuários (python -m src.auth.cli seed)
ALLOWED_USER_EMAILS=andre@avs.com.br,susana@avs.com.br,aline@avs.com.br,lucas.silva@avs.com.br

# Opcional: login Microsoft Entra ID (AUTH_PROVIDER=m365)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
